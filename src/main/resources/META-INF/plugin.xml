<idea-plugin>
    <id>com.github.gitworktree</id>
    <name>Git Worktree Tools</name>
    <vendor>aix</vendor>
    <resource-bundle>messages.GitWorktreeBundle</resource-bundle>
    <description><![CDATA[
        Git Worktree manager for IntelliJ IDEA. Create, inspect, remove, lock, unlock, quickly switch, and compare files across worktrees directly inside the IDE.

        支持在 IntelliJ IDEA 中直接管理 Git Worktree，包括创建、查看、删除、锁定、解锁、快速切换以及跨 Worktree 文件对比。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Git Worktree"
                    anchor="bottom"
                    factoryClass="com.github.gitworktree.toolwindow.WorktreeToolWindowFactory"
                    icon="/icons/pluginIcon.svg"/>

        <projectConfigurable
                parentId="tools"
                instance="com.github.gitworktree.settings.GitWorktreeConfigurable"
                id="com.github.gitworktree.settings"
                displayName="Git Worktree"/>

        <notificationGroup id="GitWorktree"
                           displayType="BALLOON"
                           toolWindowId="Git Worktree"/>

        <projectService serviceImplementation="com.github.gitworktree.settings.GitWorktreeSettings"/>

        <applicationService serviceImplementation="com.github.gitworktree.git.GitWorktreeManager"/>
    </extensions>

    <actions>
        <!-- Git menu group -->
        <group id="GitWorktree.MainMenu" text="%group.GitWorktree.MainMenu.text" popup="true">
            <add-to-group group-id="GitRepositoryActions" anchor="last"/>

            <action id="GitWorktree.Add"
                    class="com.github.gitworktree.actions.AddWorktreeAction"
                    text="%action.GitWorktree.Add.text"
                    description="%action.GitWorktree.Add.description"
                    icon="/icons/worktreeBranch.svg"/>

            <action id="GitWorktree.Remove"
                    class="com.github.gitworktree.actions.RemoveWorktreeAction"
                    text="%action.GitWorktree.Remove.text"
                    description="%action.GitWorktree.Remove.description"/>

            <action id="GitWorktree.Lock"
                    class="com.github.gitworktree.actions.LockWorktreeAction"
                    text="%action.GitWorktree.Lock.text"
                    description="%action.GitWorktree.Lock.description"/>

            <action id="GitWorktree.Unlock"
                    class="com.github.gitworktree.actions.UnlockWorktreeAction"
                    text="%action.GitWorktree.Unlock.text"
                    description="%action.GitWorktree.Unlock.description"/>

            <separator/>

            <action id="GitWorktree.QuickSwitch"
                    class="com.github.gitworktree.actions.QuickSwitchAction"
                    text="%action.GitWorktree.QuickSwitch.text"
                    description="%action.GitWorktree.QuickSwitch.description"/>
        </group>

        <!-- Editor context menu -->
        <action id="GitWorktree.CompareWithWorktree"
                class="com.github.gitworktree.actions.CompareWithWorktreeAction"
                text="%action.GitWorktree.CompareWithWorktree.text"
                description="%action.GitWorktree.CompareWithWorktree.description">
            <add-to-group group-id="EditorPopupMenu.Run" anchor="after" relative-to-action="Vcs.ShowDiffWithLocal"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <!-- VCS Log context menu -->
        <action id="GitWorktree.AddFromLog"
                class="com.github.gitworktree.actions.AddWorktreeFromLogAction"
                text="%action.GitWorktree.AddFromLog.text"
                description="%action.GitWorktree.AddFromLog.description"
                icon="/icons/worktreeBranch.svg">
            <add-to-group group-id="Vcs.Log.ContextMenu" anchor="last"/>
        </action>

        <!-- Git Branches popup context menu -->
        <action id="GitWorktree.AddFromBranch"
                class="com.github.gitworktree.actions.AddWorktreeFromBranchAction"
                text="%action.GitWorktree.AddFromBranch.text"
                description="%action.GitWorktree.AddFromBranch.description"
                icon="/icons/worktreeBranch.svg">
            <add-to-group group-id="Git.Branch" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
